{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hotel-st-cloud-pages",
  "compatibility_date": "2026-05-03",
  "main": "src/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "PLANNER_DATA",
      "id": "23e0e4247bdb47a29f501158a2c935d6"
    }
  ]
}
